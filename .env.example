# Copy this file to .env only if the project needs optional RAG Vector DB support.

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# Embedding provider selection
# Supported examples: openai, external, local, none
EMBEDDING_PROVIDER=none

# OpenAI example
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Generic hosted provider example
EMBEDDING_API_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=

# Local embedding model example
LOCAL_EMBEDDING_ENDPOINT=
LOCAL_EMBEDDING_MODEL=
